<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>
        <!-- Console Appender -->
        <Console name="ConsoleLogger" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="ConsoleLogger"/>
        </Root>

        <Logger name="com.testcreator" level="debug" additivity="false">
            <AppenderRef ref="ConsoleLogger"/>
        </Logger>

        <Logger name="com.testcreator.util.DBConnectionMaker" level="debug" additivity="false">
            <AppenderRef ref="ConsoleLogger"/>
        </Logger>

    </Loggers>

</Configuration>